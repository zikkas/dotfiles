[diff]
    pager="delta"

[merge]
    command = "nvim"
    args = ["-d"]

[data]

    {{- $name := "" -}}
    {{- if hasKey . "name" -}}
    {{-   $name = .name -}}
    {{- else -}}
    {{-   $name = promptString "What is your Git name for this machine?" -}}
    {{- end -}}    

    {{- $email := "" -}}
    {{- if hasKey . "email" -}}
    {{-   $email = .email -}}
    {{- else -}}
    {{-   $email = promptString "What is your Git email address for this machine?" -}}
    {{- end -}}

[git]
    autoCommit = true
    autoPush = true
